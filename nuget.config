<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Restore this suite only from nuget.org.

    A stale machine-wide NuGet config on some dev/build machines registers fallback
    package folders that no longer exist (e.g. 'C:\Program Files (x86)\Microsoft\Xamarin\NuGet\').
    NuGet requires every configured fallback folder to exist, so a missing one makes the
    ResolvePackageAssets MSBuild task throw and *every* PackageReference appears unresolved
    (McTools, Microsoft.Xrm, XrmToolBox, System.ServiceModel, ...). Clearing the inherited
    fallback folders here makes restore deterministic across machines and IDE vs CLI builds.
  -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
