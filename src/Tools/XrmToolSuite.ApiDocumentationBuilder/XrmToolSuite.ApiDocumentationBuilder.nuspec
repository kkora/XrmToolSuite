<?xml version="1.0" encoding="utf-8"?>
<package>
  <metadata>
    <!-- Tool Library rules (xrmtoolbox.com/documentation/for-developers):
         1) version MUST equal the assembly version of your DLL
         2) tags MUST start with "XrmToolBox" plus extra words
         3) dependency MUST be on "XrmToolBox" (NOT XrmToolBoxPackage)
         4) DLL goes under a "Plugins" folder
         5) iconUrl is required and must be your own icon -->
    <id>XrmToolSuite.ApiDocumentationBuilder</id>
    <version>1.2026.7.12</version>
    <title>API Documentation Builder for XrmToolBox</title>
    <authors>Kanchan Kora</authors>
    <owners>Kanchan Kora</owners>
    <projectUrl>https://github.com/kkora/XrmToolSuite/blob/main/src/Tools/XrmToolSuite.ApiDocumentationBuilder/README.md</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/kkora/XrmToolSuite/main/icon.png</iconUrl>
    <readme>README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <description>Documents Dataverse Custom APIs (parameters, responses, binding, plugin) as a redaction-safe reference and an OpenAPI-style JSON spec; exports Markdown, self-contained HTML, JSON, and OpenAPI JSON. Read-only; never invokes APIs; masks secrets.</description>
    <summary>Documents Dataverse Custom APIs (parameters, responses, binding, plugin) as a redaction-safe reference and an OpenAPI-style JSON spec; exports Markdown, self-contained HTML, JSON, and OpenAPI JSON. Read-only; never invokes APIs; masks secrets.</summary>
    <releaseNotes>1.2026.7.12: The API list now starts unchecked so preview/export include only the APIs you check (search no longer leaves hidden APIs selected).</releaseNotes>
    <repository type="git" url="https://github.com/kkora/XrmToolSuite" />
    <tags>XrmToolBox Dataverse Dynamics365 PowerPlatform</tags>
    <dependencies>
      <dependency id="XrmToolBox" version="1.2025.10.74" />
    </dependencies>
  </metadata>
  <files>
    <file src="README.md" target="README.md" />
    <!-- Ship ONLY your DLL; XrmToolBox already contains the SDK and shared libs -->
    <file src="bin\Release\net48\XrmToolSuite.ApiDocumentationBuilder.dll" target="lib\net48\Plugins" />
  </files>
</package>
