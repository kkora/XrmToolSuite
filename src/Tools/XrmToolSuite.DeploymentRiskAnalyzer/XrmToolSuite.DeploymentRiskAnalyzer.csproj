<Project Sdk="Microsoft.NET.Sdk">
  <!-- TargetFramework, WinForms, XrmToolBoxPackage, shared core, and versioning
       come from src/Tools/Directory.Build.props (root props sets Version). -->
  <PropertyGroup>
    <AssemblyName>XrmToolSuite.DeploymentRiskAnalyzer</AssemblyName>
    <!-- Per-tool version: bump when THIS tool changes (scripts/Bump-Tool.ps1). Must equal the nuspec <version>. -->
    <Version>1.2026.7.11</Version>
    <RootNamespace>XrmToolSuite.DeploymentRiskAnalyzer</RootNamespace>
    <Description>Deployment Risk Analyzer - pre-deployment risk analysis for XrmToolBox</Description>
    <!-- This tool ships ClosedXML + PdfSharp/MigraDoc with its nupkg, so deps must land in the output -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <ItemGroup>
    <!-- Suite-shared reporters (JSON/Markdown/HTML/Excel/PDF) and AI/offline summarization, compiled
         in as source. Opt-in (unlike Shared\Core which every tool globs) because they carry the
         Newtonsoft/ClosedXML/MigraDoc/HttpClient dependencies wired below. -->
    <Compile Include="..\..\Shared\Reporting\**\*.cs" LinkBase="Shared\Reporting" />
    <Compile Include="..\..\Shared\Summarization\**\*.cs" LinkBase="Shared\Summarization" />
  </ItemGroup>

  <ItemGroup>
    <!-- AI summary calls the AI provider APIs over HttpClient (net48 BCL assembly; not shipped) -->
    <Reference Include="System.Net.Http" />
    <!-- Newtonsoft is compiled against but NOT shipped (XrmToolBox provides it) -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="ClosedXML" Version="0.102.3" />
    <!-- Native PDF export (no HTML round-trip). GDI build = System.Drawing, net48-compatible,
         pure-managed (no SkiaSharp native binaries). Ships in the Plugins ROOT like ClosedXML. -->
    <PackageReference Include="PDFsharp-MigraDoc-GDI" Version="1.50.5147" />
  </ItemGroup>

  <!-- Extends the suite's DeployToXTB with the Excel-export dependency chain. These go in the
       a per-tool subfolder (Plugins\<AssemblyName>) so XrmToolBox can resolve the tool's ClosedXML
       reference during plugin analysis; isolated per tool, resolved at runtime by the AssemblyResolve handler (dep types stay out of signatures, so plugin analysis never needs them). -->
  <Target Name="DeployGuardDependencies" AfterTargets="DeployToXrmToolBox" Condition="'$(DeployToXTB)' == 'true'">
    <ItemGroup>
      <GuardDeps Include="$(TargetDir)ClosedXML.dll;$(TargetDir)DocumentFormat.OpenXml.dll;$(TargetDir)ExcelNumberFormat.dll;$(TargetDir)SixLabors.Fonts.dll;$(TargetDir)XLParser.dll;$(TargetDir)Irony.dll;$(TargetDir)System.IO.Packaging.dll;$(TargetDir)System.Numerics.Vectors.dll;$(TargetDir)System.Runtime.CompilerServices.Unsafe.dll;$(TargetDir)System.Buffers.dll;$(TargetDir)System.Memory.dll;$(TargetDir)System.Threading.Tasks.Extensions.dll;$(TargetDir)PdfSharp-gdi.dll;$(TargetDir)PdfSharp.Charting-gdi.dll;$(TargetDir)MigraDoc.DocumentObjectModel-gdi.dll;$(TargetDir)MigraDoc.Rendering-gdi.dll;$(TargetDir)MigraDoc.RtfRendering-gdi.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(GuardDeps)" DestinationFolder="$(AppData)\MscrmTools\XrmToolBox\Plugins\$(AssemblyName)" SkipUnchangedFiles="true" Condition="Exists('%(GuardDeps.Identity)')" />
  </Target>
</Project>
