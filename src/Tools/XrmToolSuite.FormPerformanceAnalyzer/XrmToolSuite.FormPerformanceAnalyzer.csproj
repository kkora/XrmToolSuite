<Project Sdk="Microsoft.NET.Sdk">
  <!-- TargetFramework, WinForms, XrmToolBoxPackage reference, and the shared core
       all come from src/Tools/Directory.Build.props. Keep tool csproj files minimal. -->
  <PropertyGroup>
    <RootNamespace>XrmToolSuite.FormPerformanceAnalyzer</RootNamespace>
    <AssemblyName>XrmToolSuite.FormPerformanceAnalyzer</AssemblyName>
    <!-- Per-tool version: bump when THIS tool changes (scripts/Bump-Tool.ps1). Must equal the nuspec <version>. -->
    <Version>1.2026.7.10</Version>
    <description>Scores model-driven main forms by static load 'heaviness' (tabs, sections, fields, controls, subgrids, scripts, business rules) with bands and optimization recommendations.</description>
  </PropertyGroup>
</Project>
