<?xml version="1.0" encoding="utf-8"?>
<package>
  <metadata>
    <!-- Tool Library rules (xrmtoolbox.com/documentation/for-developers):
         1) version MUST equal the assembly version of your DLL
         2) tags MUST start with "XrmToolBox" plus extra words
         3) dependency MUST be on "XrmToolBox" (NOT XrmToolBoxPackage)
         4) DLL goes under a "Plugins" folder
         5) iconUrl is required and must be your own icon -->
    <id>XrmToolSuite.ManagedSolutionImpactChecker</id>
    <version>1.2026.7.9</version>
    <title>Managed Solution Impact Checker for XrmToolBox</title>
    <authors>Kanchan Kora</authors>
    <owners>Kanchan Kora</owners>
    <projectUrl>https://github.com/kkora/XrmToolSuite/blob/main/src/Tools/XrmToolSuite.ManagedSolutionImpactChecker/README.md</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/kkora/XrmToolSuite/main/icon.png</iconUrl>
    <readme>README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <description>Read-only impact analysis for importing/upgrading/patching/deleting a managed solution. Analyzes solution layering (unmanaged customizations sitting above managed layers), overwrite and deletion risk with explicit Upgrade-vs-Update/Patch semantics (an Upgrade deletes components missing from the incoming solution — and their data — while Update/Patch do not), missing dependencies, publisher prefix mismatches, and restrictive managed properties. Produces a banded impact score, a per-path risk breakdown, a pre-upgrade checklist, rollback guidance, and a CAB-ready report (Excel/PDF/JSON/HTML). Never performs the import or upgrade.</description>
    <summary>Read-only managed-solution layering / upgrade / patch / delete impact analysis with an impact score, pre-upgrade checklist, rollback guidance, and CAB-ready Excel/PDF/JSON/HTML report.</summary>
    <releaseNotes>1.2026.7.9: Every export now offers to open the saved file. FetchXML Performance Analyzer: 'Load from view' pretty-prints the FetchXML. Internal: per-tool versioning - future releases update only the tools that changed.</releaseNotes>
    <tags>XrmToolBox Dataverse Dynamics365 PowerPlatform ALM Solutions ManagedSolution Upgrade</tags>
    <dependencies>
      <dependency id="XrmToolBox" version="1.2025.10.74" />
    </dependencies>
  </metadata>
  <files>
    <file src="README.md" target="README.md" />
    <file src="bin\Release\net48\XrmToolSuite.ManagedSolutionImpactChecker.dll" target="lib\net48\Plugins" />
    <!-- Excel-export (ClosedXML) + native-PDF (PdfSharp/MigraDoc-GDI) chains ship in a per-tool
         SUBFOLDER named after this tool's assembly (lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker),
         NOT the shared Plugins root — this is the XrmToolBox store convention (cf. Ryr.ExcelExport,
         Maverick.PCF.Builder) and it isolates our dep versions so they can never collide with another
         tool's copy in the shared AppDomain. The tool keeps ClosedXML/PdfSharp/MigraDoc types out of
         all signatures (method-body locals only), so MEF composition never loads them at scan time and
         the tool lists fine without them on the probe path; at runtime the scoped AssemblyResolve handler
         in ManagedSolutionImpactCheckerPlugin loads them from this subfolder (with a root fallback). -->
    <file src="bin\Release\net48\ClosedXML.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\DocumentFormat.OpenXml.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\ExcelNumberFormat.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\XLParser.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\Irony.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\SixLabors.Fonts.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\System.IO.Packaging.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\System.Numerics.Vectors.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\System.Runtime.CompilerServices.Unsafe.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\System.Buffers.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\System.Memory.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\System.Threading.Tasks.Extensions.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\PdfSharp-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\PdfSharp.Charting-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\MigraDoc.DocumentObjectModel-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\MigraDoc.Rendering-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
    <file src="bin\Release\net48\MigraDoc.RtfRendering-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.ManagedSolutionImpactChecker" />
  </files>
</package>
