<?xml version="1.0" encoding="utf-8"?>
<package>
  <metadata>
    <!-- Tool Library rules (xrmtoolbox.com/documentation/for-developers):
         1) version MUST equal the assembly version of your DLL
         2) tags MUST start with "XrmToolBox" plus extra words
         3) dependency MUST be on "XrmToolBox" (NOT XrmToolBoxPackage)
         4) DLL goes under a "Plugins" folder
         5) iconUrl is required and must be your own icon -->
    <id>XrmToolSuite.EnvironmentInventory</id>
    <version>1.2026.7.11</version>
    <title>Environment Inventory for XrmToolBox</title>
    <authors>Kanchan Kora</authors>
    <owners>Kanchan Kora</owners>
    <projectUrl>https://github.com/kkora/XrmToolSuite/blob/main/src/Tools/XrmToolSuite.EnvironmentInventory/README.md</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/kkora/XrmToolSuite/main/icon.png</iconUrl>
    <readme>README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <description>Inventories a Dataverse environment (solutions, tables, security roles, users/teams/business units, plugins, workflows, web resources, custom APIs, environment variables and connection references) into one searchable, filterable catalog with Excel/CSV/JSON/Markdown/HTML/Word/PDF export. Read-only; never reads or exports secret values.</description>
    <summary>Read-only, searchable inventory of a Dataverse environment across solutions, metadata, security, automation, web/dev and configuration, with Excel/CSV/JSON/Markdown/HTML/Word/PDF export.</summary>
    <releaseNotes>Normalize newlines in component-detail values so multi-line output renders correctly.</releaseNotes>
    <repository type="git" url="https://github.com/kkora/XrmToolSuite" />
    <tags>XrmToolBox Dataverse Dynamics365 PowerPlatform</tags>
    <dependencies>
      <dependency id="XrmToolBox" version="1.2025.10.74" />
    </dependencies>
  </metadata>
  <files>
    <file src="README.md" target="README.md" />
    <file src="bin\Release\net48\XrmToolSuite.EnvironmentInventory.dll" target="lib\net48\Plugins" />
    <!-- Excel/Word-export (ClosedXML) + native-PDF (PdfSharp/MigraDoc-GDI) chains ship in a per-tool
         SUBFOLDER named after this tool's assembly (lib\net48\Plugins\XrmToolSuite.EnvironmentInventory),
         NOT the shared Plugins root — this is the XrmToolBox store convention (cf. Ryr.ExcelExport,
         Maverick.PCF.Builder) and it isolates our dep versions so they can never collide with another
         tool's copy in the shared AppDomain. The tool keeps ClosedXML/PdfSharp/MigraDoc types out of
         all signatures (method-body locals only), so MEF composition never loads them at scan time and
         the tool lists fine without them on the probe path; at runtime the scoped AssemblyResolve handler
         in EnvironmentInventoryPlugin loads them from this subfolder (with a root fallback). -->
    <file src="bin\Release\net48\ClosedXML.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\DocumentFormat.OpenXml.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\ExcelNumberFormat.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\XLParser.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\Irony.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\SixLabors.Fonts.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\System.IO.Packaging.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\System.Numerics.Vectors.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\System.Runtime.CompilerServices.Unsafe.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\System.Buffers.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\System.Memory.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\System.Threading.Tasks.Extensions.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\PdfSharp-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\PdfSharp.Charting-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\MigraDoc.DocumentObjectModel-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\MigraDoc.Rendering-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
    <file src="bin\Release\net48\MigraDoc.RtfRendering-gdi.dll" target="lib\net48\Plugins\XrmToolSuite.EnvironmentInventory" />
  </files>
</package>
